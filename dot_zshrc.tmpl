ZSH_CONFIG="$HOME/.config/zsh"

source "$ZSH_CONFIG/01-options.zsh"
source "$ZSH_CONFIG/02-completion.zsh"
source "$ZSH_CONFIG/03-oh-my-zsh.zsh"
source "$ZSH_CONFIG/04-keybinds.zsh"
source "$ZSH_CONFIG/05-aliases.zsh"
source "$ZSH_CONFIG/06-tools.zsh"
{{- if eq .chezmoi.os "linux" }}
source "$ZSH_CONFIG/platform-linux.zsh"
{{- else if eq .chezmoi.os "darwin" }}
source "$ZSH_CONFIG/platform-darwin.zsh"
{{- end }}

[[ -f "$HOME/.config.zsh" ]] && source "$HOME/.config.zsh"