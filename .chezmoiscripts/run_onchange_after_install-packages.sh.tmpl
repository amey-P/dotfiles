{{- /* Package installation script - runs only when content changes */ -}}
#!/bin/bash

set -uo pipefail

{{- if eq .chezmoi.os "linux" }}
{{-   if or (eq .chezmoi.osRelease.id "debian") (eq .chezmoi.osRelease.id "ubuntu") }}
echo "Installing packages via apt..."
sudo apt update || true
sudo apt install -y \
  git stow curl gcc cmake libssl-dev pkg-config luarocks \
  vim emacs universal-ctags tmux zsh nodejs \
  ripgrep neofetch fzf neovim yazi || echo "WARNING: apt install failed. Install packages manually."

{{-   else if eq .chezmoi.osRelease.id "arch" }}
echo "Installing packages via pacman..."
sudo pacman -Syu --noconfirm \
  git stow curl gcc cmake openssl pkg-config luarocks \
  vim emacs ctags tmux zsh nodejs \
  ripgrep neofetch fzf neovim yazi || echo "WARNING: pacman install failed. Install packages manually."

{{-   else }}
echo "Unsupported Linux distribution: {{ .chezmoi.osRelease.id }}"
echo "Please install packages manually."
{{-   end }}

{{- else if eq .chezmoi.os "darwin" }}
echo "Installing packages via brew..."
brew install \
  git curl gcc cmake vim emacs neovim tmux zsh \
  node ripgrep bat fd fzf exa || echo "WARNING: brew install failed. Install packages manually."

{{- end }}

echo "Installing npm global packages..."
npm install -g {{ range .npm_global }}{{ . }} {{ end }}2>/dev/null || echo "WARNING: npm global install failed."